# Ruta del archivo SQLite (se crea solo en el primer arranque)
DATABASE_PATH=./data/gestionvet.db

# Credenciales de acceso
AUTH_USER=admin
AUTH_PASSWORD=changeme

# Sesión JWT
JWT_SECRET=cambiame-por-64-caracteres-hex-aleatorios
AUTH_SESSION_DAYS=30

# Moneda (se lee en RUNTIME: cambiar locale/moneda y toda la app se adapta,
# sin rebuildear — ideal para Docker)
CURRENCY_LOCALE=es-CL
CURRENCY=CLP
